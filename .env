# ============================================================
# RTSP Stream Configuration
# ============================================================
# Format: "CameraName,rtsp://url;CameraName2,rtsp://url2"
# Separate multiple streams with semicolons (;)
RTSP_STREAMS=Camera_1,rtsp://13.232.170.243:8554/cam10;Camera_2,rtsp://13.232.170.243:8554/cam11

# Alternative: Define streams individually
# RTSP_URL_1=rtsp://username:password@192.168.1.100:554/stream1
# RTSP_NAME_1=Front Door
# RTSP_URL_2=rtsp://username:password@192.168.1.101:554/stream1
# RTSP_NAME_2=Parking Lot

# ============================================================
# Detection Settings
# ============================================================
# Minimum confidence threshold for object detection (0.0-1.0)
CONFIDENCE_THRESHOLD=0.5

# Cooldown period in seconds between saving detections of the
# same class from the same camera (prevents duplicate saves)
DETECTION_COOLDOWN=5

# Run detection every N frames (higher = less CPU usage)
DETECTION_INTERVAL=15

# ============================================================
# Stream Settings
# ============================================================
# Seconds to wait before reconnecting a disconnected stream
RECONNECT_DELAY=5

# ============================================================
# Application Settings
# ============================================================
# Server port (inside container)
APP_PORT=8000
